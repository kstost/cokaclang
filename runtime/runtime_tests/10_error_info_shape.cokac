변수 seen = 거짓;
변수 msg = "";
변수 code = "";
변수 line = 0;

시도 {
    던지기 "에러모양검증";
} 잡기(메시지, 정보) {
    seen = 참;
    msg = 메시지;
    code = 정보.코드;
    line = 정보.줄;
    단언(타입(정보) == "객체", "오류 정보 타입 실패");
    단언(길이(정보.코드) > 0, "오류 코드 비어있음");
    단언(정보.줄 > 0, "오류 줄 번호 실패");
} 마침 {
    단언(참, "마침 블록 실패");
}

단언(seen, "예외 잡기 실패");
단언(문자포함(msg, "에러모양검증"), "예외 메시지 불일치");
단언(길이(code) > 0, "오류 코드 불일치");
단언(line > 0, "오류 줄 불일치");
