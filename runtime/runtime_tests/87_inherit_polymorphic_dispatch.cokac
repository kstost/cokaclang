형식 알림 {
    행동 렌더() {
        반환 "알림";
    }
}

형식 이메일알림 물려받기 알림 {
    속성 제목 = "";

    만들기(제목값) {
        자기.제목 = 제목값;
    }

    행동 렌더() {
        반환 "메일:" + 자기.제목;
    }
}

형식 문자알림 물려받기 알림 {
    속성 번호 = "";

    만들기(번호값) {
        자기.번호 = 번호값;
    }

    행동 렌더() {
        반환 "문자:" + 자기.번호;
    }
}

변수 목록 = [
    인스턴스생성(이메일알림, ["배포완료"]),
    인스턴스생성(문자알림, ["010-0000-0000"]),
    인스턴스생성(이메일알림, ["점검예정"])
];

변수 결과 = "";
변수 항목 = 없음;
동안 (변수 i = 0; i < 길이(목록); i = i + 1) {
    항목 = 목록[i];
    결과 = 결과 + 항목.렌더();
    만약 (i + 1 < 길이(목록)) {
        결과 = 결과 + "|";
    }
}

단언(결과 == "메일:배포완료|문자:010-0000-0000|메일:점검예정", "다형성 디스패치 실패");
