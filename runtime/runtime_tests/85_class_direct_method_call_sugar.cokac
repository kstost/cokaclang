형식 계산기 {
    속성 누적 = 0;

    행동 더하기(v) {
        자기.누적 = 자기.누적 + v;
        반환 자기.누적;
    }

    행동 읽기() {
        반환 자기.누적;
    }
}

형식 고급계산기 물려받기 계산기 {
    행동 두배더하기(v) {
        반환 자기.더하기(v * 2);
    }
}

변수 c = 인스턴스생성(고급계산기);
단언(c.더하기(3) == 3, "직접 메서드 호출 1 실패");
단언(c.두배더하기(4) == 11, "상속 메서드 내부 직접 호출 실패");
단언(c.읽기() == 11, "상태 누적 실패");
