형식 계산엔진 {
    속성 계수 = 1;

    만들기(계수값) {
        자기.계수 = 계수값;
    }

    행동 전처리(x) {
        반환 x;
    }

    행동 계산(x) {
        반환 자기.전처리(x) * 자기.계수;
    }
}

형식 제곱엔진 물려받기 계산엔진 {
    행동 전처리(x) {
        반환 x * x;
    }
}

변수 e1 = 인스턴스생성(계산엔진, [3]);
변수 e2 = 인스턴스생성(제곱엔진, [3]);

단언(e1.계산(4) == 12, "기본 알고리즘 계산 실패");
단언(e2.계산(4) == 48, "오버라이드 알고리즘 계산 실패");
