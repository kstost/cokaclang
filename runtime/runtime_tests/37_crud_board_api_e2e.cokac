변수 posts = [];
변수 nextId = 1;
변수 port = 19140;
변수 server = 서버열기(port, "127.0.0.1");

함수 path_id(path) {
    변수 parts = 문자분할(path, "/");
    만약 (길이(parts) >= 3) {
        반환 숫자(parts[2]);
    }
    반환 -1;
}

함수 handle_request(req) {
    변수 method = req.메서드;
    변수 path = req.경로;

    // POST /posts
    만약 (method == "POST" 그리고 path == "/posts") {
        변수 body = 자료파싱(req.본문);
        변수 post = {
            id: nextId,
            title: body.title,
            content: body.content
        };
        배열추가(posts, post);
        nextId = nextId + 1;
        반환 {status: 201, body: 자료문자열화(post)};
    }

    // GET /posts
    만약 (method == "GET" 그리고 path == "/posts") {
        반환 {status: 200, body: 자료문자열화(posts)};
    }

    // GET /posts/:id
    만약 (method == "GET" 그리고 문자시작(path, "/posts/")) {
        변수 id = path_id(path);
        동안 (변수 i = 0; i < 길이(posts); i = i + 1) {
            만약 (posts[i].id == id) {
                반환 {status: 200, body: 자료문자열화(posts[i])};
            }
        }
        반환 {status: 404, body: "{\"error\":\"not_found\"}"};
    }

    // PUT /posts/:id
    만약 (method == "PUT" 그리고 문자시작(path, "/posts/")) {
        변수 id = path_id(path);
        변수 body = 자료파싱(req.본문);
        동안 (변수 i = 0; i < 길이(posts); i = i + 1) {
            만약 (posts[i].id == id) {
                posts[i] = {id: id, title: body.title, content: body.content};
                반환 {status: 200, body: 자료문자열화(posts[i])};
            }
        }
        반환 {status: 404, body: "{\"error\":\"not_found\"}"};
    }

    // DELETE /posts/:id
    만약 (method == "DELETE" 그리고 문자시작(path, "/posts/")) {
        변수 id = path_id(path);
        동안 (변수 i = 0; i < 길이(posts); i = i + 1) {
            만약 (posts[i].id == id) {
                배열삭제(posts, i);
                반환 {status: 200, body: "{\"deleted\":true}"};
            }
        }
        반환 {status: 404, body: "{\"error\":\"not_found\"}"};
    }

    반환 {status: 404, body: "{\"error\":\"route_not_found\"}"};
}

함수 call_api(method, path, payload) {
    변수 acceptTask = 비동기요청받기(server);

    변수 opts = {
        메서드: method,
        로컬차단: 거짓,
        최대시간초: 3,
        연결시간초: 1,
        재시도: 0,
        헤더: {"Content-Type": "application/json"}
    };

    만약 (payload != 없음) {
        객체설정(opts, "본문", 자료문자열화(payload));
    }

    변수 reqTask = 비동기가져오기요청("http://127.0.0.1:19140" + path, opts);

    변수 req = 대기최대(acceptTask, 3000);
    변수 result = handle_request(req);
    단언(응답보내기(req.연결, result.status, result.body, {"Content-Type": "application/json"}), "응답보내기 실패");
    단언(연결닫기(req.연결), "요청 연결닫기 실패");

    반환 대기최대(reqTask, 3000);
}

변수 r1 = call_api("POST", "/posts", {title: "첫글", content: "내용1"});
단언(r1.상태 == 201, "POST 1 상태 실패");
변수 p1 = 응답자료(r1);
단언(p1.id == 1, "POST 1 id 실패");

변수 r2 = call_api("POST", "/posts", {title: "둘째글", content: "내용2"});
단언(r2.상태 == 201, "POST 2 상태 실패");
변수 p2 = 응답자료(r2);
단언(p2.id == 2, "POST 2 id 실패");

변수 r3 = call_api("GET", "/posts", 없음);
단언(r3.상태 == 200, "GET 목록 상태 실패");
변수 list1 = 응답자료(r3);
단언(길이(list1) == 2, "GET 목록 길이 실패");

변수 r4 = call_api("GET", "/posts/1", 없음);
단언(r4.상태 == 200, "GET 단건 상태 실패");
변수 g1 = 응답자료(r4);
단언(g1.title == "첫글", "GET 단건 title 실패");

변수 r5 = call_api("PUT", "/posts/1", {title: "첫글수정", content: "내용수정"});
단언(r5.상태 == 200, "PUT 상태 실패");
변수 u1 = 응답자료(r5);
단언(u1.title == "첫글수정", "PUT title 실패");

변수 r6 = call_api("DELETE", "/posts/2", 없음);
단언(r6.상태 == 200, "DELETE 상태 실패");
변수 d = 응답자료(r6);
단언(d.deleted == 참, "DELETE body 실패");

변수 r7 = call_api("GET", "/posts", 없음);
변수 list2 = 응답자료(r7);
단언(길이(list2) == 1, "DELETE 이후 목록 길이 실패");
단언(list2[0].id == 1, "DELETE 이후 남은 id 실패");

변수 r8 = call_api("GET", "/posts/2", 없음);
단언(r8.상태 == 404, "삭제된 글 조회 상태 실패");

단언(연결닫기(server), "서버 닫기 실패");
