변수 s = 서버열기(19142, "127.0.0.1");
변수 a = 비동기요청받기(s);
변수 t = 비동기가져오기요청("http://127.0.0.1:19142/notfound", {로컬차단: 거짓, 재시도: 0, 최대시간초: 3, 연결시간초: 1});

변수 req = 대기최대(a, 3000);
응답보내기(req.연결, 404, "{\"error\":\"nf\"}", {"Content-Type":"application/json"});
연결닫기(req.연결);

변수 resp = 대기최대(t, 3000);
단언(resp.상태 == 404, "비동기가져오기요청 non2xx 상태 실패");
단언(응답자료(resp).error == "nf", "응답자료 non2xx 파싱 실패");

단언(연결닫기(s), "서버닫기 실패");
