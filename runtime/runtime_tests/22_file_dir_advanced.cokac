변수 root = "runtime_fd_tmp";
변수 srcDir = 경로합치기(root, "src");
변수 dstDir = 경로합치기(root, "dst");
변수 a = 경로합치기(srcDir, "a.txt");
변수 b = 경로합치기(srcDir, "b.txt");
변수 c = 경로합치기(srcDir, "c.txt");

만약 (디렉토리존재(root)) {
    디렉토리삭제재귀(root);
}
디렉토리생성(root);
디렉토리생성(srcDir);

파일쓰기줄들(a, ["x", "y", "z"]);
변수 lines = 파일읽기줄들(a);
단언(길이(lines) == 3, "파일쓰기줄들/읽기줄들 실패");
단언(lines[1] == "y", "파일읽기줄들 내용 실패");

단언(파일복사(a, b), "파일복사 실패");
단언(파일존재(b), "파일복사 결과 없음");
단언(파일이동(b, c), "파일이동 실패");
단언(!파일존재(b), "파일이동 원본 잔존");
단언(파일존재(c), "파일이동 대상 부재");

변수 info = 파일정보(c);
단언(info.파일 == 참, "파일정보 파일 플래그 실패");
단언(info.크기 > 0, "파일정보 크기 실패");
단언(파일수정시각(c) > 0, "파일수정시각 실패");

변수 lst = 디렉토리목록(srcDir);
단언(길이(lst) == 2, "디렉토리목록 길이 실패");

단언(디렉토리복사(srcDir, dstDir), "디렉토리복사 실패");
단언(파일존재(경로합치기(dstDir, "a.txt")), "디렉토리복사 결과 실패");

단언(디렉토리삭제재귀(root), "디렉토리삭제재귀 실패");
단언(!경로존재(root), "삭제 후 경로존재 실패");
