변수 동물메서드 = {
    초기화: 함수(자기, 이름) {
        객체설정(자기, "이름", 이름);
    },
    말하기: 함수(자기) {
        반환 "동물:" + 자기.이름;
    }
};

변수 동물 = 클래스생성("동물", 동물메서드);
단언(클래스확인(동물), "클래스확인 실패");

변수 개메서드 = {
    말하기: 함수(자기) {
        반환 "멍멍:" + 자기.이름;
    }
};

변수 개 = 클래스생성("개", 개메서드, 동물);
변수 뽀삐 = 인스턴스생성(개, ["뽀삐"]);

변수 말 = 메서드호출(뽀삐, "말하기");
단언(말 == "멍멍:뽀삐", "오버라이드 메서드 실패");
단언(상속확인(뽀삐, 동물), "상속확인 실패");
단언(상속확인(개, 동물), "클래스 상속확인 실패");
