변수 root = "runtime_tmp";
변수 txt = 경로합치기(root, "io.txt");
변수 json = 경로합치기(root, "io.json");

만약 (!디렉토리존재(root)) {
    디렉토리생성(root);
}

파일쓰기(txt, "line1\nline2");
단언(파일존재(txt), "파일쓰기/파일존재 실패");
단언(파일크기(txt) > 0, "파일크기 실패");

변수 lines = 파일읽기줄들(txt);
단언(길이(lines) == 2, "파일읽기줄들 실패");

자료쓰기(json, {ok: 참, n: 7});
변수 parsed = 자료읽기(json);
단언(parsed.ok == 참, "자료읽기 실패");
단언(parsed.n == 7, "자료 숫자 값 실패");

단언(경로존재(json), "경로존재 실패");
단언(길이(절대경로(json)) > 0, "절대경로 실패");

단언(파일삭제(txt), "파일삭제(txt) 실패");
단언(파일삭제(json), "파일삭제(json) 실패");
단언(디렉토리삭제(root), "디렉토리삭제 실패");
