변수 s = 서버열기(19124, "127.0.0.1");
변수 a = 비동기요청받기(s);
변수 r = 비동기가져오기요청("http://127.0.0.1:19124/j", {로컬차단: 거짓, 재시도: 0, 최대시간초: 3, 연결시간초: 1});

변수 req = 대기최대(a, 3000);
응답보내기(req.연결, 200, "{\"ok\":true,\"n\":7}", {"Content-Type":"application/json"});
연결닫기(req.연결);

변수 resp = 대기최대(r, 3000);
변수 j = 응답자료(resp);
단언(j.ok == 참 그리고 j.n == 7, "응답자료 JSON 파싱 실패");
단언(응답헤더값(resp, "content-type") == "application/json", "응답헤더값 실패");

연결닫기(s);
