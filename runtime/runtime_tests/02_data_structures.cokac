변수 arr = [3, 1, 2];
배열추가(arr, 4);
단언(길이(arr) == 4, "배열추가 실패");

변수 sorted = 배열정렬(arr);
단언(sorted[0] == 1, "배열정렬 실패");
단언(sorted[3] == 4, "배열정렬 끝값 실패");

변수 joined = 배열문자열합치기(["a", "b", "c"], "-");
단언(joined == "a-b-c", "배열문자열합치기 실패");

변수 s = 문자치환("a_b_c", "_", "-");
단언(s == "a-b-c", "문자치환 실패");
단언(문자포함(s, "b"), "문자포함 실패");

변수 obj = {이름: "cokac", 버전: 1};
객체설정(obj, "활성", 참);
단언(객체가짐(obj, "활성"), "객체설정/객체가짐 실패");
단언(obj.이름 == "cokac", "객체 속성 접근 실패");
