비동기 함수 더하기(a, b) {
    반환 a + b;
}

변수 a = 더하기(1, 2);
변수 b = 더하기(10, 20);
변수 all = 작업모두([a, b]);
변수 rs = 대기최대(all, 2000);
단언(타입(rs) == "배열", "작업모두 결과 타입 실패");
단언(길이(rs) == 2, "작업모두 결과 길이 실패");
단언(rs[0] == 3, "작업모두 첫 값 실패");
단언(rs[1] == 30, "작업모두 두번째 값 실패");

변수 c1 = 더하기(4, 5);
변수 c2 = 더하기(6, 7);
변수 winner = 작업경주([c1, c2]);
변수 w = 대기최대(winner, 2000);
단언(w == 9 또는 w == 13, "작업경주 결과 실패");

변수 st = 비동기통계();
단언(타입(st) == "객체", "비동기통계 타입 실패");
단언(st.누적등록 >= 1, "비동기통계 누적등록 실패");
단언(st.대기호출 >= 1, "비동기통계 대기호출 실패");
