변수 o = {a: 1};
객체설정(o, "b", 2);
단언(객체가짐(o, "a"), "객체가짐 a 실패");
단언(객체가짐(o, "b"), "객체가짐 b 실패");

변수 ks = 객체키들(o);
변수 vs = 객체값들(o);
단언(길이(ks) == 2, "객체키들 길이 실패");
단언(길이(vs) == 2, "객체값들 길이 실패");

변수 c = 객체복사(o);
객체설정(c, "c", 3);
단언(!객체가짐(o, "c"), "객체복사 독립성 실패");

객체합치기(o, {d: 4, a: 10});
단언(o.a == 10, "객체합치기 덮어쓰기 실패");
단언(o.d == 4, "객체합치기 추가 실패");

단언(객체삭제(o, "b"), "객체삭제 실패");
단언(!객체가짐(o, "b"), "객체삭제 후 존재 실패");
