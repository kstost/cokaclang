변수 cur = 현재디렉토리();
변수 res = 명령실행결과("printf \"$XVAR|$(pwd)\"", {
    환경: {XVAR: "v1"},
    작업디렉토리: cur,
    시간제한초: 2
});
단언(res.코드 == 0, "명령실행결과 코드 실패");
변수 out = 문자다듬기(res.표준출력);
변수 parts = 문자분할(out, "|");
단언(길이(parts) == 2, "명령실행결과 분할 실패");
단언(parts[0] == "v1", "명령 환경변수 전달 실패");
단언(parts[1] == cur, "명령 작업디렉토리 전달 실패");
