변수 src = [1, 2, 3, 4, 5];
변수 mapped = 배열맵(src, 함수(v, i) { 반환 v + i; });
단언(mapped[0] == 1, "배열맵 인덱스 반영 실패");
단언(mapped[4] == 9, "배열맵 끝값 실패");

변수 odds = 배열필터(src, 함수(v, i) { 반환 v % 2 == 1 그리고 i >= 0; });
단언(길이(odds) == 3, "배열필터 길이 실패");
단언(odds[0] == 1 그리고 odds[2] == 5, "배열필터 값 실패");

변수 sum = 배열리듀스(src, 함수(acc, v, i) { 반환 acc + v + i; }, 0);
단언(sum == 25, "배열리듀스 실패");

변수 a = [10, 20, 30];
변수 removed = 배열삭제(a, 1);
단언(removed == 20, "배열삭제 반환 실패");
단언(길이(a) == 2, "배열삭제 후 길이 실패");

배열삽입(a, 1, 99);
단언(a[1] == 99, "배열삽입 실패");

변수 sliced = 배열슬라이스([0,1,2,3,4], 1, 4);
단언(길이(sliced) == 3, "배열슬라이스 길이 실패");
단언(sliced[0] == 1 그리고 sliced[2] == 3, "배열슬라이스 값 실패");
