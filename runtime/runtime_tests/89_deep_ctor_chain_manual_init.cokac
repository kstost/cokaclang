형식 A {
    속성 a = 0;

    행동 A초기화(v) {
        자기.a = v;
    }
}

형식 B 물려받기 A {
    속성 b = 0;

    행동 B초기화(va, vb) {
        자기.A초기화(va);
        자기.b = vb;
    }
}

형식 C 물려받기 B {
    속성 c = 0;

    만들기(va, vb, vc) {
        자기.B초기화(va, vb);
        자기.c = vc;
    }

    행동 합() {
        반환 자기.a + 자기.b + 자기.c;
    }
}

변수 x = 인스턴스생성(C, [10, 20, 30]);
단언(x.a == 10 그리고 x.b == 20 그리고 x.c == 30, "다단 상속 수동 초기화 실패");
단언(x.합() == 60, "다단 상속 계산 실패");
