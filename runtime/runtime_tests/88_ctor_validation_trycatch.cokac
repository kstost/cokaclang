형식 사용자 {
    속성 아이디 = 0;
    속성 이름 = "";

    만들기(아이디값, 이름값) {
        만약 (아이디값 <= 0) {
            던지기 "유효하지 않은 사용자 아이디";
        }
        자기.아이디 = 아이디값;
        자기.이름 = 이름값;
    }

    행동 라벨() {
        반환 문자열(자기.아이디) + ":" + 자기.이름;
    }
}

변수 실패잡힘 = 거짓;
시도 {
    변수 잘못 = 인스턴스생성(사용자, [0, "x"]);
} 잡기(메시지, 오류정보) {
    실패잡힘 = 문자포함(메시지, "유효하지 않은 사용자 아이디");
} 마침 {}

단언(실패잡힘, "생성자 검증 예외 잡기 실패");

변수 정상 = 인스턴스생성(사용자, [7, "코캑"]);
단언(정상.라벨() == "7:코캑", "정상 생성자 경로 실패");
