변수 포트 = 19091;
변수 서버 = 서버열기(포트, "127.0.0.1");
단언(서버 > 0, "서버열기 실패");

변수 acc = 비동기요청받기(서버);
변수 reqTask = 비동기가져오기요청("http://127.0.0.1:19091/ping", {
    메서드: "GET",
    로컬차단: 거짓,
    최대시간초: 3,
    연결시간초: 1,
    재시도: 0
});

변수 req = 대기최대(acc, 3000);
단언(req.메서드 == "GET", "서버 수신 메서드 실패");
단언(req.경로 == "/ping", "서버 수신 경로 실패");
단언(응답보내기(req.연결, 200, "pong"), "응답보내기 실패");
단언(연결닫기(req.연결), "클라이언트 연결닫기 실패");

변수 resp = 대기최대(reqTask, 3000);
단언(resp.상태 == 200, "HTTP 상태코드 실패");
단언(응답본문(resp) == "pong", "HTTP 본문 실패");
단언(resp.성공 == 참, "HTTP 성공 플래그 실패");

단언(연결닫기(서버), "서버 연결닫기 실패");
