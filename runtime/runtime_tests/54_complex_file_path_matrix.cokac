변수 root = "matrix_root";
변수 copy = "matrix_copy";
만약 (경로존재(root)) { 디렉토리삭제재귀(root); }
만약 (경로존재(copy)) { 디렉토리삭제재귀(copy); }

디렉토리생성(root);
디렉토리생성(경로합치기(root, "a"));
디렉토리생성(경로합치기(root, "a/b"));
디렉토리생성(경로합치기(root, "c"));

변수 p1 = 경로합치기(root, "a/b/one.txt");
변수 p2 = 경로합치기(root, "a/two.txt");
변수 p3 = 경로합치기(root, "c/three.json");

파일쓰기(p1, "111");
파일쓰기줄들(p2, ["a","b","c"]);
자료쓰기(p3, {k: 7, arr: [1,2,3]});

단언(해시파일(p1) == 해시문자열("111"), "해시파일/문자열 일치 실패");
단언(길이(파일읽기줄들(p2)) == 3, "파일줄 읽기 실패");
단언(자료읽기(p3).k == 7, "자료읽기 실패");

단언(디렉토리복사(root, copy), "디렉토리복사 실패");
단언(파일존재(경로합치기(copy, "a/b/one.txt")), "복사 파일 누락");

변수 norm = 경로정규화("./matrix_copy/a/../a/b/./one.txt");
단언(문자포함(norm, "matrix_copy/a/b/one.txt"), "경로정규화 복합 실패");

변수 rel = 상대경로(copy, 경로합치기(copy, "a/b/one.txt"));
단언(rel == "a/b/one.txt", "상대경로 복합 실패");

단언(디렉토리삭제재귀(root), "root 삭제 실패");
단언(디렉토리삭제재귀(copy), "copy 삭제 실패");
