변수 out = 명령실행("printf 'hello'");
단언(out == "hello", "명령실행 출력 불일치");

변수 ok = 명령실행결과("printf 'x'", {시간제한초: 2});
단언(ok.코드 == 0, "명령실행결과 코드 실패");
단언(ok.성공 == 참, "명령실행결과 성공 플래그 실패");
단언(ok.표준출력 == "x", "명령실행결과 표준출력 실패");

변수 to = 명령실행결과("sleep 2", {시간제한초: 1});
단언(to.코드 == 124, "명령 시간제한 코드 실패");
단언(to.성공 == 거짓, "명령 시간제한 성공 플래그 실패");
단언(문자포함(to.표준에러, "시간 제한"), "명령 시간제한 표준에러 실패");
