형식 A {
    행동 a() { 반환 1; }
}

형식 B 물려받기 A {
    행동 b() { 반환 2; }
}

형식 C 물려받기 B {
    행동 c() { 반환 3; }
}

변수 i = 인스턴스생성(C);
단언(메서드호출(i, "a") == 1, "상속 체인 A 메서드 실패");
단언(메서드호출(i, "b") == 2, "상속 체인 B 메서드 실패");
단언(메서드호출(i, "c") == 3, "상속 체인 C 메서드 실패");
단언(상속확인(i, A), "상속확인 A 실패");
단언(상속확인(i, B), "상속확인 B 실패");
