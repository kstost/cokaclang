단언(정수(3.9) == 3, "정수 절삭 실패");
단언(정수(-3.9) == -3, "정수 음수 절삭 실패");
단언(절댓값(-0.0) == 0, "절댓값 -0 실패");
단언(숫자("0012") == 12, "문자열 숫자 변환 실패");
단언(최대(-100, 0, 999, 42) == 999, "최대 경계 실패");
단언(최소(-100, 0, 999, 42) == -100, "최소 경계 실패");

변수 huge = 9007199254740991;
단언(문자열(huge) == "9007199254740991", "큰 정수 문자열화 실패");
