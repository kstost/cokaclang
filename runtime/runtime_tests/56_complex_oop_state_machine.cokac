변수 methods = {
    초기화: 함수(self) {
        객체설정(self, "items", []);
        객체설정(self, "state", "ready");
    },
    추가: 함수(self, v) {
        만약 (self.state != "ready") { 반환 거짓; }
        배열추가(self.items, v);
        반환 참;
    },
    잠금: 함수(self) {
        객체설정(self, "state", "locked");
        반환 참;
    },
    합계: 함수(self) {
        반환 배열리듀스(self.items, 함수(acc, x, i){ 반환 acc + x; }, 0);
    }
};

변수 Repo = 클래스생성("Repo", methods);
변수 r = 인스턴스생성(Repo);

동안 (변수 i = 1; i <= 100; i = i + 1) {
    단언(메서드호출(r, "추가", [i]), "상태머신 추가 실패");
}
단언(메서드호출(r, "합계") == 5050, "상태머신 합계 실패");
단언(메서드호출(r, "잠금"), "상태머신 잠금 실패");
단언(메서드호출(r, "추가", [999]) == 거짓, "잠금 이후 추가 차단 실패");
단언(메서드호출(r, "합계") == 5050, "잠금 이후 합계 불변 실패");
