형식 사용자 {
    속성 이름 = "익명";
    속성 점수 = 0;

    만들기(이름) {
        자기.이름 = 이름;
    }

    행동 이름읽기() {
        반환 자기.이름;
    }

    행동 점수증가(값) {
        자기.점수 = 자기.점수 + 값;
        반환 자기.점수;
    }
}

변수 u = 인스턴스생성(사용자, ["코캑"]);
단언(메서드호출(u, "이름읽기") == "코캑", "생성자 이름 설정 실패");
단언(메서드호출(u, "점수증가", [5]) == 5, "점수 증가 1 실패");
단언(메서드호출(u, "점수증가", [7]) == 12, "점수 증가 2 실패");
