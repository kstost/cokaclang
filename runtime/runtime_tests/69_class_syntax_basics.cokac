형식 게시글 {
    속성 제목 = "";
    속성 조회수 = 0;

    만들기(제목) {
        자기.제목 = 제목;
    }

    행동 제목조회() {
        반환 자기.제목;
    }

    행동 읽기() {
        자기.조회수 = 자기.조회수 + 1;
        반환 자기.조회수;
    }
}

단언(클래스확인(게시글), "형식 선언이 클래스 객체로 생성되지 않았습니다.");

변수 글 = 인스턴스생성(게시글, ["cokac"]);
단언(메서드호출(글, "제목조회") == "cokac", "생성자/메서드 연결 실패");
단언(메서드호출(글, "읽기") == 1, "속성 기본값 또는 증가 로직 실패");
단언(메서드호출(글, "읽기") == 2, "인스턴스 상태 유지 실패");
