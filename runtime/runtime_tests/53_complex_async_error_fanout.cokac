비동기 함수 ok(v, ms) { 대기밀리초(ms); 반환 v; }
비동기 함수 boom(tag, ms) { 대기밀리초(ms); 던지기 tag; }

변수 t1 = ok(1, 10);
변수 t2 = boom("E_B2", 20);
변수 t3 = ok(3, 30);

변수 allFailed = 거짓;
시도 {
    대기최대(작업모두([t1, t2, t3]), 5000);
} 잡기(msg, info) {
    allFailed = 참;
    단언(문자포함(msg, "E_B2"), "작업모두 오류 메시지 실패");
    단언(길이(info.코드) > 0, "작업모두 오류코드 실패");
} 마침 {}
단언(allFailed, "작업모두 실패 전파 누락");

단언(작업실패(t2), "실패 task 상태 누락");
단언(문자포함(작업오류(t2), "E_B2"), "작업오류 내용 실패");

변수 r1 = 대기최대(작업경주([ok("fast", 5), boom("E_LATE", 80)]), 5000);
단언(r1 == "fast", "작업경주 성공 경로 실패");

변수 raceFailed = 거짓;
시도 {
    대기최대(작업경주([boom("E_FIRST", 3), ok("slow", 50)]), 5000);
} 잡기(msg, info) {
    raceFailed = 참;
    단언(문자포함(msg, "E_FIRST"), "작업경주 실패 메시지 실패");
} 마침 {}
단언(raceFailed, "작업경주 실패 전파 누락");
