변수 root = "runtime_async_tmp";
만약 (!디렉토리존재(root)) {
    디렉토리생성(root);
}

변수 p = 대기최대(비동기경로합치기(root, "a.txt"), 2000);
변수 okW = 대기최대(비동기파일쓰기(p, "abc"), 2000);
단언(okW == 참, "비동기파일쓰기 실패");

변수 ex = 대기최대(비동기파일존재(p), 2000);
단언(ex == 참, "비동기파일존재 실패");

변수 txt = 대기최대(비동기파일읽기(p), 2000);
단언(txt == "abc", "비동기파일읽기 실패");

변수 sz = 대기최대(비동기파일크기(p), 2000);
단언(sz == 3, "비동기파일크기 실패");

변수 cwd = 대기최대(비동기현재디렉토리(), 2000);
단언(길이(cwd) > 0, "비동기현재디렉토리 실패");

단언(대기최대(비동기파일삭제(p), 2000), "비동기파일삭제 실패");
단언(대기최대(비동기디렉토리삭제(root), 2000), "비동기디렉토리삭제 실패");
