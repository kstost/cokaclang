형식 문서기반 {
    속성 타입 = "";
    속성 생성시각 = "";

    행동 부모초기화(타입값, 시각값) {
        자기.타입 = 타입값;
        자기.생성시각 = 시각값;
        반환 참;
    }

    행동 헤더() {
        반환 "[" + 자기.타입 + "]";
    }
}

형식 공지문 물려받기 문서기반 {
    속성 제목 = "";
    속성 본문 = "";
    속성 로그 = [];

    만들기(제목값, 본문값, 시각값) {
        배열추가(자기.로그, "시작");
        자기.부모초기화("공지", 시각값);
        자기.제목 = 제목값;
        자기.본문 = 본문값;
        배열추가(자기.로그, "완료");
    }

    행동 요약() {
        반환 자기.헤더() + " " + 자기.제목;
    }
}

변수 p = 인스턴스생성(공지문, ["점검 안내", "본문", "2026-03-04 09:00:00"]);
단언(p.요약() == "[공지] 점검 안내", "템플릿 메서드 기반 상속 생성자 실패");
단언(길이(p.로그) == 2, "생성자 로그 길이 실패");
단언(p.로그[0] == "시작" 그리고 p.로그[1] == "완료", "생성자 단계 기록 실패");
