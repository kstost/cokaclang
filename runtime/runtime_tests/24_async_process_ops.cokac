변수 t1 = 비동기명령실행("printf 'ab'");
변수 out = 대기최대(t1, 2000);
단언(out == "ab", "비동기명령실행 실패");

변수 t2 = 비동기명령실행결과("printf 'ok'", {시간제한초: 2});
변수 r2 = 대기최대(t2, 2000);
단언(r2.코드 == 0, "비동기명령실행결과 코드 실패");
단언(r2.표준출력 == "ok", "비동기명령실행결과 출력 실패");

변수 t3 = 비동기명령실행결과("cat", {입력: "stdin-data", 시간제한초: 2});
변수 r3 = 대기최대(t3, 2000);
단언(r3.표준출력 == "stdin-data", "비동기명령 stdin 실패");
