형식 동물 {
    속성 종 = "동물";

    행동 말하기() {
        반환 "...";
    }
}

형식 개 물려받기 동물 {
    행동 말하기() {
        반환 "멍";
    }
}

형식 카운터 {
    속성 값 = 3;

    행동 읽기() {
        반환 자기.값;
    }
}

변수 뽀삐 = 인스턴스생성(개);
단언(메서드호출(뽀삐, "말하기") == "멍", "오버라이드 동작 실패");
단언(상속확인(뽀삐, 동물), "상속확인 실패");

변수 c = 인스턴스생성(카운터);
단언(메서드호출(c, "읽기") == 3, "생성자 없는 속성 기본값 초기화 실패");
