변수 s = 0;
동안 (변수 i = 0; i < 10; i = i + 1) {
    만약 (i == 3) { 계속; }
    만약 (i == 8) { 중단; }
    s = s + i;
}
단언(s == 25, "중단/계속 제어 실패");

함수 카운터시작(n) {
    변수 v = n;
    함수 증가() {
        v = v + 1;
        반환 v;
    }
    반환 증가;
}

변수 inc = 카운터시작(10);
단언(inc() == 11, "클로저 첫 호출 실패");
단언(inc() == 12, "클로저 캡처 유지 실패");
