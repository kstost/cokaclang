변수 port = 19141;
변수 server = 서버열기(port, "127.0.0.1");

함수 once(path) {
    변수 acceptTask = 비동기요청받기(server);
    변수 reqTask = 비동기가져오기요청("http://127.0.0.1:19141" + path, {
        메서드: "GET",
        로컬차단: 거짓,
        최대시간초: 3,
        연결시간초: 1,
        재시도: 0
    });

    변수 req = 대기최대(acceptTask, 3000);
    변수 seen = req.경로;
    단언(응답보내기(req.연결, 200, "ok", {"Content-Type": "text/plain"}), "응답보내기 실패");
    단언(연결닫기(req.연결), "요청 연결닫기 실패");
    변수 _ = 대기최대(reqTask, 3000);
    반환 seen;
}

변수 p1 = once("/posts?%ED%8E%98%EC%9D%B4%EC%A7%80=2&%ED%81%AC%EA%B8%B0=10");
단언(문자포함(p1, "페이지=2"), "한글 키 페이지 percent-decode 실패");
단언(문자포함(p1, "크기=10"), "한글 키 크기 percent-decode 실패");

변수 p2 = once("/posts?%EA%B2%80%EC%83%89=%ED%95%B4%EC%8B%9C&%EC%83%81%ED%83%9C=%EA%B2%8C%EC%8B%9C");
단언(문자포함(p2, "검색=해시"), "한글 키/값 검색 percent-decode 실패");
단언(문자포함(p2, "상태=게시"), "한글 키/값 상태 percent-decode 실패");

단언(연결닫기(server), "서버 닫기 실패");
