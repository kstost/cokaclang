비동기 함수 계산작업(i) {
    // 가변 지연으로 큐/대기 경로를 복합적으로 통과
    대기밀리초(5 + (i % 4) * 7);
    반환 {id: i, value: i * i};
}

변수 tasks = [];
동안 (변수 i = 1; i <= 20; i = i + 1) {
    배열추가(tasks, 계산작업(i));
}

단언(비동기큐길이() >= 1, "비동기 큐 초기 상태 실패");

변수 all = 작업모두(tasks);
변수 results = 대기최대(all, 8000);
단언(길이(results) == 20, "작업모두 결과 길이 실패");

변수 sum = 배열리듀스(results, 함수(acc, item, idx) {
    반환 acc + item.value;
}, 0);

// 1^2 + ... + 20^2 = 2870
단언(sum == 2870, "비동기 파이프라인 합계 실패");

비동기 함수 느림() { 대기밀리초(120); 반환 "slow"; }
비동기 함수 빠름() { 대기밀리초(3); 반환 "fast"; }
변수 winner = 대기최대(작업경주([빠름(), 느림()]), 5000);
단언(winner == "fast", "작업경주 파이프라인 실패");

변수 st = 비동기통계();
단언(st.누적등록 >= 22, "비동기통계 누적등록 실패");
단언(st.누적완료 >= 21, "비동기통계 누적완료 실패");
단언(st.대기호출 >= 2, "비동기통계 대기호출 실패");
