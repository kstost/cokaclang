변수 obj = {이름: "cokac", 값: 7, ok: 참};
변수 j = 자료문자열화(obj);
변수 p = 자료파싱(j);
단언(p.이름 == "cokac", "자료파싱/문자열화 실패");
단언(p.값 == 7, "자료 값 실패");

변수 pretty = 자료예쁘게문자열화(obj, 2);
단언(문자포함(pretty, "\n"), "자료예쁘게문자열화 개행 실패");

변수 h1 = 해시문자열("abc");
변수 h2 = 해시문자열("abc");
단언(h1 == h2, "해시문자열 결정성 실패");
단언(길이(h1) == 16, "해시문자열 길이 실패");

변수 b64 = 베이스육십사인코드("hello");
변수 raw = 베이스육십사디코드(b64);
단언(raw == "hello", "베이스64 왕복 실패");
