단언(경로이름("/a/b/c.txt") == "c.txt", "경로이름 실패");
단언(상위경로("/a/b/c.txt") == "/a/b", "상위경로 실패");
단언(확장자("/a/b/c.txt") == "txt", "확장자 실패");
단언(확장자("/a/b/.gitignore") == "", "숨김파일 확장자 실패");

변수 p = 경로합치기("/tmp", "x/y");
단언(p == "/tmp/x/y", "경로합치기 실패");

변수 n1 = 경로정규화("./a/../b/./c");
단언(n1 == "b/c", "경로정규화 상대 실패");

변수 n2 = 경로정규화("/a//b/../c");
단언(n2 == "/a/c", "경로정규화 절대 실패");

단언(상대경로("/x/y", "/x/y") == ".", "상대경로 동일경로 실패");
단언(상대경로("/x/y", "/x/y/z/t") == "z/t", "상대경로 하위 실패");
